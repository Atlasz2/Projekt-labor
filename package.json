{
  "name": "tour-trail-app",
  "version": "1.0.0",
  "description": "Nagyvazsony turisztikai app monorepo (admin + mobile)",
  "private": true,
  "scripts": {
    "start": "npm run admin:dev",
    "build": "npm run admin:build",
    "test": "echo \"No root test suite configured. Use admin/mobile commands explicitly.\"",
    "admin:dev": "npm --prefix admin run dev",
    "admin:build": "npm --prefix admin run build",
    "admin:preview": "npm --prefix admin run preview",
    "mobile:analyze": "flutter analyze mobile_app",
    "mobile:test": "flutter test mobile_app",
    "mobile:run": "flutter run --project-dir mobile_app"
  }
}
