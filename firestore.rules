rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function adminByUid() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function adminByEmailDoc() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'admin';
    }

    function isAdmin() {
      return adminByUid() || adminByEmailDoc();
    }

    match /{document=**} {
      allow read: if true;
    }

    match /user_progress/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;

      match /completed_stations/{stationId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /trips/{tripId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stations/{stationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /accommodations/{accommodationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /about/{aboutId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contact/{contactId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
