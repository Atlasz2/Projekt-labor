rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Primary admin check: UID-based only (cannot be spoofed by creating a doc)
    function adminByUid() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Email-doc fallback: also requires a uid field in the doc matching the caller
    function adminByEmailDoc() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.email == request.auth.token.email
        && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'admin'
        && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.uid == request.auth.uid;
    }

    function isAdmin() {
      return adminByUid() || adminByEmailDoc();
    }

    // Validates a user's self-write to their own progress document:
    // - totalPoints can only increase (no direct point reduction)
    // - completedStations can only grow (no removing completed stations)
    function isValidProgressUpdate() {
      let incoming = request.resource.data;
      let existing = resource.data;
      let pointsOk = !incoming.keys().hasAny(['totalPoints'])
        || incoming.totalPoints >= (existing.get('totalPoints', 0));
      let stationsOk = !incoming.keys().hasAny(['completedStations'])
        || incoming.completedStations.hasAll(existing.get('completedStations', []));
      return pointsOk && stationsOk;
    }

    match /user_progress/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Admin: unrestricted write
      allow write: if isAdmin();

      // User: can only write to their own doc, with monotonic constraints.
      // Create is restricted to zeroed counters so a fresh doc cannot start
      // with fabricated points or completed items.
      allow create: if isSignedIn() && request.auth.uid == userId
        && (!request.resource.data.keys().hasAny(['totalPoints'])
            || request.resource.data.totalPoints == 0)
        && (!request.resource.data.keys().hasAny(['completedStations'])
            || request.resource.data.completedStations.size() == 0)
        && (!request.resource.data.keys().hasAny(['completedEvents'])
            || request.resource.data.completedEvents.size() == 0)
        && (!request.resource.data.keys().hasAny(['completedTripIds'])
            || request.resource.data.completedTripIds.size() == 0);
      allow update: if isSignedIn() && request.auth.uid == userId && isValidProgressUpdate();

      match /completed_stations/{stationId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      match /completed_events/{eventId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      match /unlocked_achievements/{achievementId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || (request.auth.token.email != null && request.auth.token.email == userId)
        || isAdmin()
      );
      allow create: if isSignedIn() && (
        request.auth.uid == userId
        || (request.auth.token.email != null && request.auth.token.email == userId)
      ) && (
        !request.resource.data.keys().hasAny(['role'])
        || request.resource.data.role == 'user'
      );
      allow update: if isSignedIn() && (
        request.auth.uid == userId
        || (request.auth.token.email != null && request.auth.token.email == userId)
      ) && (
        !request.resource.data.keys().hasAny(['role'])
        || !resource.data.keys().hasAny(['role'])
        || request.resource.data.role == resource.data.role
      );
      allow create, update, delete: if isAdmin();
    }

    match /usernames/{normalizedName} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    // Leaderboard: anyone can read; users can only update their own entry
    // with display name only — points must match their stored user_progress
    match /public_leaderboard/{userId} {
      allow read: if true;
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Admin: full write access
      allow create, update: if isAdmin();

      // User: can write their own entry, but points must match user_progress.totalPoints
      // and the user_progress document must exist (prevents bypass via missing doc).
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && exists(/databases/$(database)/documents/user_progress/$(userId))
        && request.resource.data.points ==
             get(/databases/$(database)/documents/user_progress/$(userId)).data.totalPoints;
    }

    match /trips/{tripId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stations/{stationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /accommodations/{accommodationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /about/{aboutId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contact/{contactId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /achievements/{achievementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bug_reports/{reportId} {
      allow create: if isSignedIn();
      // Admins read everything; a signed-in user may read their own reports
      // so the in-app "previous reports" history works (query is filtered by
      // reported_by.user_id == request.auth.uid).
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.reported_by.user_id == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Daily analytics snapshots written by the admin dashboard (one doc per day).
    // Internal-only: admins read and write, nobody else.
    match /stats_daily/{day} {
      allow read, write: if isAdmin();
    }
  }
}

