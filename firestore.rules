rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ================================================
    // ÁLTALÁNOS OLVASÁSI JOG - Mindenki olvashat
    // ================================================
    match /{document=**} {
      allow read: if true;
    }
    
    // ================================================
    // USER PROGRESS - Csak saját adatot írhat
    // ================================================
    match /user_progress/{userId} {
      // A felhasználó olvashatja és írhatja a saját dokumentumát
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Subcollection: completed_stations
      match /completed_stations/{stationId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // ================================================
    // ADMIN ÍRÁSI JOG - Minden egyéb collection
    // ================================================
        match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /trips/{tripId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
    
    match /stations/{stationId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
    
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
    
    match /accommodations/{accommodationId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
    
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
    
    match /about/{aboutId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
    
    match /contact/{contactId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
  }
}
